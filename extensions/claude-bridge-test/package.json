{
  "name": "claude-bridge-test",
  "displayName": "Claude Bridge Test",
  "description": "Test extension to interact with Claude Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-bridge-test.openDialog",
        "title": "Open Claude Bridge Dialog"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/node": "^18.x",
    "typescript": "^5.3.0"
  }
}
